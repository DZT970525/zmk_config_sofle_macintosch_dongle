#include <behaviors.dtsi>
#include <dt-bindings/zmk/behaviors.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/ext_power.h>
#include <dt-bindings/zmk/rgb.h>

#define FUNC 1
#define RES 2
#define BOT bootloader

/ {
    input_processors {

        zip_temp_layer: zip_temp_layer {
            compatible = "zmk,input-processor-temp-layer";
            #input-processor-cells = <2>;
        };

        ip_behaviors0: ip_behaviors0 {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;
            type = <INPUT_EV_KEY>;
            codes = <INPUT_BTN_0>;
            bindings = <&kp RIGHT>;
        };
        ip_behaviors1: ip_behaviors1 {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;
            type = <INPUT_EV_KEY>;
            codes = <INPUT_BTN_1>;
            bindings = <&kp LEFT>;
        };
        ip_behaviors2: ip_behaviors2 {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;
            type = <INPUT_EV_KEY>;
            codes = <INPUT_BTN_2>;
            bindings = <&kp DOWN>;
        };
        ip_behaviors3: ip_behaviors3 {
            compatible = "zmk,input-processor-behaviors";
            #input-processor-cells = <0>;
            type = <INPUT_EV_KEY>;
            codes = <INPUT_BTN_3>;
            bindings = <&kp UP>;
        };
    };
};

/ {
    behaviors {
        td0: tap_dance_0 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <400>;
            bindings = <&mkp LCLK>, <&bt BT_CLR>;
        };
    };
    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <500>;
            bindings = <&kp &kp>;
        };
    };

    behaviors {
         sp_sc: behavior_spacescroll {
           compatible = "zmk,behavior-hold-tap";
           #binding-cells = <2>;
           flavor = "tap-preferred";     /* 单击优先 */
           tapping-term-ms = <200>;       /* 长按阈值 */
           bindings = <&none &kp>;        /* hold=none, tap=space */
        };
    };

    behaviors {
        BLE_encoder: BLE_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&bt BT_NXT>, <&bt BT_PRV>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

         default_layer {
            display-name = "DEFAULT";
           bindings = <
                                                                            &BOT
&kp ESC    &kp N1   &kp N2     &kp N3   &kp N4     &kp N5    &kp CAPS                      &kp PRINTSCREEN          &kp N6       &kp N7      &kp N8     &kp N9    &kp N0     &kp BSPC            
&kp TAB    &kp Q    &kp W      &kp E    &kp R      &kp T                                                            &kp Y        &kp U       &kp I      &kp O     &kp P      &kp BSLH
&kp LSHFT  &kp A    &kp S      &kp D    &kp F      &kp G     &mkp LCLK                     &mkp LCLK                &kp H        &kp J       &kp K      &kp L     &kp RETURN &kp RETURN
&kp LCTRL  &kp Z    &kp X      &kp C    &kp V      &kp B     &mkp LCLK   &mkp RCLK         &kp PAGE_DOWN   &kp PAGE_UP  &kp N        &kp M       &kp COMMA  &kp DOT   &kp EQUAL  &kp DEL
                    &kp LGUI   &kp LALT &kp SPACE  &kp SPACE &to 1                         &to 2                    &kp KP_PLUS  &kp MINUS   &kp STAR   &kp SLASH
           >;
           sensor-bindings = <&inc_dec_kp DOWN UP>, <&inc_dec_kp LEFT RIGHT>;
        };


        lower_layer {
            display-name = "DIR+NUM";
            bindings = <
                                                                                 &BOT
&kp ESC     &kp LPAR  &none      &none      &kp DOLLAR  &kp CAPS      &kp CAPS                         &kp PRINTSCREEN                 &kp PRINTSCREEN         &kp KP_N7      &kp KP_N8        &kp KP_N9      &kp RPAR      &kp BACKSPACE
&kp TAB     &none     &none      &kp UP     &none       &kp KP_NUMLOCK                                                                      &none         &kp KP_N4     &kp KP_N5         &kp KP_N6      &kp KP_COMMA  &kp BACKSLASH
&kp LSHFT   &kp A     &kp LEFT   &kp DOWN   &kp RIGHT   &none      &mkp LCLK                        &trans                          &none         &kp KP_N1      &kp KP_N2        &kp KP_N3      &kp KP_ENTER  &kp RETURN
&kp LCTRL   &kp Z     &kp X      &kp C      &kp V       &none      &mkp LCLK    &mkp RCLK           &kp PAGE_DOWN    &kp PAGE_UP      &none         &kp KP_N0      &kp KP_N0        &kp KP_DOT     &kp KP_EQUAL  &kp DEL
                      &kp LCMD   &kp LALT   &kp SPACE   &kp SPACE  &to 0                            &to 2                           &kp KP_PLUS   &kp KP_MINUS   &kp KP_ASTERISK  &kp KP_DIVIDE

            >;
            sensor-bindings = <&BLE_encoder>,
                              <&inc_dec_kp C_VOLUME_DOWN C_VOLUME_UP>;
        };

        raise_layer {
            display-name = "FUNC+SYM";
            bindings = <
                                                                       &BOT
&kp ESC     &kp F1    &kp F2     &kp F3     &kp F4     &bl BL_DEC  &bt BT_CLR                &kp C_MUTE                &bl BL_INC   &kp PRINTSCREEN       &none      &none       &none       &kp BACKSPACE
&kp TAB     &kp F5    &kp F6     &kp F7     &kp F8     &none                                                           &none        &none       &kp LBKT   &kp RBKT    &none       &none
&kp LSHFT   &kp F9    &kp F10    &kp F11    &kp F12    &none       &mkp LCLK                 &none                     &none        &none       &kp SEMI   &kp APOS    &kp RETURN  &kp RETURN
&kp LCTRL   &kp Z     &kp X      &kp C      &kp V      &none       &mkp LCLK    &mkp RCLK    &kp PAGE_DOWN  &kp PAGE_UP  &none        &none       &kp COMMA  &kp DOT     &none       &kp DEL
                      &kp LCMD   &kp LALT   &kp SPACE  &kp SPACE   &to 1                     &to 0                     &none        &none       &none      &none
            >;
        }; 
        MOUSE_layer {
            display-name = "MOUSE";
            bindings = <
                                                                         &BOT
&kp ESC   &kp N1    &kp N2     &kp N3   &kp N4   &kp N5     &kp CAPS                       &kp PRINTSCREEN       &none      &none      &none   &none         &none  &kp BSPC            
&kp TAB   &kp Q     &kp W      &kp E    &kp R    &kp T                                                        &none      &mkp MB3   &none   &none         &none  &none
&kp CAPS  &kp A     &kp S      &kp D    &kp F    &none      &mkp LCLK                        &mkp LCLK        &none      &mkp LCLK  &none   &none         &none  &none
&kp LSHFT &kp Z     &kp X      &kp C    &kp V    &kp B      &msc SCRL_DOWN   &msc SCRL_UP    &none  &none     &none      &mkp RCLK  &none   &msc SCRL_UP  &none  &none
                    &kp LCTRL  &kp LGUI &kp LALT &kp SPACE  &to 0                                   &to 0     &kp SPACE  &to 0      &none   &msc SCRL_DOWN
            >;
        };

    };
};
